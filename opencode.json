{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "codebase-memory": {
            "type": "local",
            "enabled": true,
            "command": [
                "codebase-memory-mcp",
            ]
        },
        "playwright": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "@playwright/mcp@latest",
                "--browser=firefox"
            ]
        }
    },
    "plugin": [
        "@dietrichgebert/ponytail"
    ]
}