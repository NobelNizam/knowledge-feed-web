# Knowledge Feed API — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Server ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Auth (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ---
JWT_SECRET=change-me-64-hex-chars
REFRESH_TOKEN_SECRET=change-me-64-hex-chars
SESSION_SECRET=change-me-64-hex-chars

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql://user:password@localhost:5432/knowledge_feed
DATABASE_USER=knowledge_feed
DATABASE_PASSWORD=knowledge_feed
DATABASE_NAME=knowledge_feed

# --- Cache / Queue (Redis) ---
REDIS_URL=redis://localhost:6379
REDIS_PORTS=6379:6379

# --- Object storage (MinIO) ---
MINIO_USER=minioadmin
MINIO_PASS=minioadmin

# --- NVIDIA NIM (LLM + embeddings) ---
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# --- Optional tuning ---
PIPELINE_CHUNK_SIZE=512
PIPELINE_CHUNK_OVERLAP=64
FACT_CHECK_MIN_CONFIDENCE=0.6
ARXIV_QUERY_TOPICS=
NCBI_API_KEY=

# --- Internal (do not change unless you know why) ---
# Salt for hashing anonymous viewer fingerprints. Generate per environment.
ANON_VIEW_SALT=change-me
